# OpenAI API key (keep local, never commit real key)
OPENAI_API_KEY=sk-...

# Optional: model name
OPENAI_MODEL=gpt-4o-mini

# Local server port
PORT=8787

# Optional: local budget limit (USD) and token pricing overrides
MAX_BUDGET_USD=10
OPENAI_COST_INPUT_PER_1M=0.15
OPENAI_COST_OUTPUT_PER_1M=0.60
